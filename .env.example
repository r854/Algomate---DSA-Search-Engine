# Google OAuth Credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Session Secret (random string)
SESSION_SECRET=a_very_secret_string_123

# Public URL of the app (required for Google Auth callback)
# Example: https://algomate.onrender.com
BASE_URL=http://localhost:3000

# Node Environment
NODE_ENV=production
PORT=3000
